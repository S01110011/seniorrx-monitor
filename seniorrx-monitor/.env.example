# Copie para .env e preencha com valores locais. NUNCA commitar .env real.

# --- Banco de dados ---
DATABASE_URL=postgresql+psycopg://seniorrx:changeme@localhost:5432/seniorrx
TEST_DATABASE_URL=postgresql+psycopg://seniorrx:changeme@localhost:5432/seniorrx_test

# --- API ---
# Em producao, defina SENIORRX_ENV=production: a API passa a EXIGIR a key
# (fail-closed) e emite HSTS. Gere uma key forte, ex: python -c "import secrets; print(secrets.token_urlsafe(32))"
SENIORRX_ENV=development
SENIORRX_API_KEY=changeme-generate-a-strong-random-key
SENIORRX_CORS_ORIGINS=http://localhost:8501
SENIORRX_RATE_LIMIT=120/minute

# --- Dashboard ---
SENIORRX_API_URL=http://localhost:8000

# --- MLOps ---
MLFLOW_TRACKING_URI=./mlruns
