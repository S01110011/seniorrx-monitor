# Normalizacao de fim de linha entre plataformas (Windows/Linux/CI).
* text=auto eol=lf

# Scripts shell exigem LF para executar em containers/CI.
*.sh text eol=lf

# Windows-specific
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binarios: nunca normalizar.
*.png binary
*.jpg binary
*.parquet binary
*.joblib binary
*.ipynb text
