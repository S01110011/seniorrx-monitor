# =============================================================================
# Copie para .env e preencha com valores FORTES. NUNCA commite o .env real.
# Gere todos os segredos com:  make secrets   (ou scripts/gen_secrets.sh)
# O docker-compose EXIGE POSTGRES_PASSWORD e SENIORRX_API_KEY (falha se vazios).
# =============================================================================

# --- Segredos (OBRIGATORIOS) ---
# Senha do PostgreSQL. Gere: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# Chave da API. Gere: python -c "import secrets; print(secrets.token_urlsafe(32))"
SENIORRX_API_KEY=

# --- Banco de dados ---
# Deve conter a MESMA senha de POSTGRES_PASSWORD acima.
DATABASE_URL=postgresql+psycopg://seniorrx:CHANGE_ME@localhost:5432/seniorrx
TEST_DATABASE_URL=postgresql+psycopg://seniorrx:CHANGE_ME@localhost:5432/seniorrx_test

# --- API ---
# Em producao, defina SENIORRX_ENV=production: a API EXIGE a key (fail-closed)
# e passa a emitir HSTS.
SENIORRX_ENV=development
SENIORRX_CORS_ORIGINS=http://localhost:8501
SENIORRX_RATE_LIMIT=120/minute

# --- Dashboard ---
SENIORRX_API_URL=http://localhost:8000

# --- MLOps ---
MLFLOW_TRACKING_URI=./mlruns
